rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth helper
    function isSignedIn() {
      return request.auth != null;
    }

    // Users: Anyone authed can read, only owner can write
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Skills: Authenticated read, owner write
    match /skills/{skillId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // Requests: Participants read, requester creates, recipient updates status
    match /requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.toUid == request.auth.uid 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if false; 
    }

    // Chats: Only participants in the array can read/write
    match /chats/{chatId} {
      // Allow read even if doc doesn't exist (for existence checks)
      // If it exists, user must be a participant
      allow read: if isSignedIn() && (resource == null || request.auth.uid in resource.data.participants);
      
      // Creating a new chat: user must be in the participants list
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      
      // Updating: user must be a participant
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      allow delete: if false;

      // Messages sub-collection: only participants of the parent chat can read/write
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Notifications: Only recipient can read/update
    match /notifications/{notifId} {
      allow read, update: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn(); // Allow system or other users to send notifications
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // Ratings: Authenticated read, requester can create unique rating per exchange
    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
                    && request.resource.data.fromUid == request.auth.uid
                    && !exists(/databases/$(database)/documents/ratings/$(request.resource.data.fromUid + '_' + request.resource.data.exchangeId));
      allow update, delete: if false;
    }
  }
}
